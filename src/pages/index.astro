  <script>
    /* ─── preferences (persisted via localStorage) ─── */
    const LS_KEY = 'jmlabs.prefs.v1';
    const saved = (() => {
      try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; } catch { return {}; }
    })();
    const state = {
      theme: saved.theme || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'),
      lang: saved.lang || 'es',
    };
    function persist() {
      try { localStorage.setItem(LS_KEY, JSON.stringify(state)); } catch {}
    }

    const html = document.documentElement;

    function applyTheme(v: 'dark' | 'light') {
      html.classList.toggle('dark', v === 'dark');
      html.classList.toggle('light', v === 'light');
      state.theme = v;
      persist();
    }

    function applyLang(v: 'es' | 'en') {
      html.setAttribute('lang', v);
      const esBtn = document.getElementById('lang-es');
      const enBtn = document.getElementById('lang-en');
      esBtn?.setAttribute('aria-pressed', String(v === 'es'));
      enBtn?.setAttribute('aria-pressed', String(v === 'en'));
      state.lang = v;
      persist();
    }

    /* hydrate state into DOM */
    applyTheme(state.theme as 'dark' | 'light');
    applyLang(state.lang as 'es' | 'en');

    /* wire up nav controls */
    document.getElementById('lang-es')?.addEventListener('click', () => applyLang('es'));
    document.getElementById('lang-en')?.addEventListener('click', () => applyLang('en'));
    document.getElementById('theme-btn')?.addEventListener('click', () => {
      applyTheme(state.theme === 'dark' ? 'light' : 'dark');
    });

    /* mobile drawer */
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('drawer-close');

    function openDrawer() {
      drawer?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.add('on');
      menuBtn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.remove('on');
      menuBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    menuBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer?.getAttribute('aria-hidden') === 'false') closeDrawer();
    });

    /* email un-obfuscation on load — protege de bots regex-based sin JS */
    document.querySelectorAll<HTMLAnchorElement>('[data-email-user][data-email-domain]').forEach((el) => {
      const user = el.dataset.emailUser;
      const domain = el.dataset.emailDomain;
      if (!user || !domain) return;
      const email = `${user}@${domain}`;
      el.href = `mailto:${email}`;
      const text = el.querySelector<HTMLElement>('[data-email-text]');
      if (text) text.textContent = email;
    });

    /* reveal-on-scroll — scoped a projects + col-cards (menos sobrecarga visual) */
    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) {
          en.target.classList.add('in');
          io.unobserve(en.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.project, .col-card').forEach((el) => {
      el.classList.add('reveal');
      io.observe(el);
    });

    /* scroll-spy — marca el link activo según la section visible (nav + TOC) */
    const spyLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href^="#"], .toc a[href^="#"]');
    const sectionsMap = new Map<Element, HTMLAnchorElement[]>();
    spyLinks.forEach((link) => {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) return;
      const sec = document.getElementById(id);
      if (!sec) return;
      if (!sectionsMap.has(sec)) sectionsMap.set(sec, []);
      sectionsMap.get(sec)!.push(link);
    });
    const spy = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          spyLinks.forEach((l) => l.classList.remove('active'));
          const matches = sectionsMap.get(entry.target) || [];
          matches.forEach((l) => l.classList.add('active'));
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
    sectionsMap.forEach((_, sec) => spy.observe(sec));
  </script>
